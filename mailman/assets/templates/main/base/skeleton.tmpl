{{define "skeleton"}}
<!doctype html>
<html lang="en">
    <head>
        <!-- Required meta tags -->
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">

        <link rel="stylesheet" href="{{ static "main/css/base.css" }}">

        <title>{{block "title" .}}MailMan{{end}}</title>
        <link rel="icon" href="{{ block "logourl" .}}{{ static "mailman.png" }}{{end}}" type="image/png">
        
        {{ $mode := mode }}

        <style>
            :root {
                --color-primary-rgb: {{$mode.Primary}};
                --color-primary-accent-rgb: {{$mode.PrimaryAccent}};
                --color-standout-rgb: {{$mode.StandOut}};
                --color-secondary-rgb: {{$mode.Secondary}};
                --main-color-rgb: {{$mode.Header}};
                --header-text-color-rgb: {{$mode.HeaderText}};

                --border-style: {{$mode.BorderStyle}};

                --color-primary: rgb(var(--color-primary-rgb));
                --color-primary-accent: rgb(var(--color-primary-accent-rgb));
                --color-secondary: rgb(var(--color-secondary-rgb));
                --color-standout: rgb(var(--color-standout-rgb));
                --main-color: rgb(var(--main-color-rgb));
                --header-text-color: rgb(var(--header-text-color-rgb));
            }
        </style>
        {{block "css" .}}{{end}}
    </head>
    <body id="body" class="{{$mode.Name}}" data-controller="document" data-document-modes-value="{{ json modes }}" data-document-navbar-link-selector-value=".sidebar-left a">

        {{template "navbar.tmpl" .}}

        {{block "root" .}}
            <div class="main text">
                <div class="main-left noselect">
                    {{block "left" .}} {{template "left.tmpl" .}} {{end}}
                </div>
                <div class="main-center">

                    <noscript>
                        <div class="alert-container alert alert-danger">
                            <h1>{{ T "Please enable Javascript" }}</h1>
                            <p>{{ T "Javascript is required to properly interact with this site." }}</p>
                        </div>
                    </noscript>

                    <section class="messages" data-controller="messages">
                        {{if .Data.messages}}
                            {{template "messages" . }}
                        {{end}}
                    </section>

                    {{block "content" .}}{{end}}
                </div>
            </div>
        {{end}}

        <script src="{{ static "main/js/app.js" }}" type="text/javascript"></script>
        <script src="{{ static "main/js/main.js" }}" type="text/javascript"></script>
        <script src="{{ static "main/js/htmx.min.js" }}" type="text/javascript"></script>
        
        {{block "js" .}}
        
        {{end}}
    </body>
</html>
{{end}}