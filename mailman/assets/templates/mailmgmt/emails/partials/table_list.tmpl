{{ define "table_list" }}
{{ range $idx, $email := (.Get "view.paginator.object").Results }}
    <tr class="mailmgmt-list-table--item" style="--row-index:{{ $idx }};">
        <td class="mailmgmt--table--data--check">
            <input
                type="checkbox"
                name="email"
                value="{{ $email.Email }}"
                data-table-list-target="checkbox"
                data-action="change->table-list#updateSelectAll"/>
        </td>
        <td class="mailmgmt--table--data">
            <span class="email" title="{{ $email.Email }}">{{ $email.Email }}</span>
        </td>
        <td class="mailmgmt--table--data noselect">
            <span class="mailmgmt--quota">
                {{ $email.CurrentQuota }} / {{ $email.MaxQuota }}
                {{ if ne $email.MaxQuota "~" }}
                    [{{ $email.PercentageFull }}%]
                {{ end }}
            </span>
        </td>
        <td class="mailmgmt--table--data noselect">
            {{ $email.Aliases|len }}
        </td>
        <td class="mailmgmt--table--action noselect">
            <div class="mailmgmt-list-item-actions">
                <button class="mailmgmt-action-button mailmgmt-action-alias"
                    hx-get="{{ url "mailmgmt:htmx:alias:add" }}?email={{ urlquery $email.Email }}"
                    hx-target="body"
                    hx-swap="beforeend">

                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="mailmgmt-action-icon" viewBox="0 0 16 16" data-controller="tooltip" data-tooltip-content-value="{{ T "Add new alias" }}" data-tooltip-placement-value="bottom">
                        <path d="M2 2a2 2 0 0 0-2 2v8.01A2 2 0 0 0 2 14h5.5a.5.5 0 0 0 0-1H2a1 1 0 0 1-.966-.741l5.64-3.471L8 9.583l7-4.2V8.5a.5.5 0 0 0 1 0V4a2 2 0 0 0-2-2zm3.708 6.208L1 11.105V5.383zM1 4.217V4a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v.217l-7 4.2z"/>
                        <path d="M16 12.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0m-3.5-2a.5.5 0 0 0-.5.5v1h-1a.5.5 0 0 0 0 1h1v1a.5.5 0 0 0 1 0v-1h1a.5.5 0 0 0 0-1h-1v-1a.5.5 0 0 0-.5-.5"/>
                    </svg>
                </button>
                <button class="mailmgmt-action-button mailmgmt-action-change"
                    hx-get="{{ url "mailmgmt:htmx:emails:update" }}?email={{ urlquery $email.Email }}"
                    hx-target="body"
                    hx-swap="beforeend">

                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="mailmgmt-action-icon" viewBox="0 0 16 16" data-controller="tooltip" data-tooltip-content-value="{{ T "Change Password" }}" data-tooltip-placement-value="bottom">
                        <path d="M5.338 1.59a61 61 0 0 0-2.837.856.48.48 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.7 10.7 0 0 0 2.287 2.233c.346.244.652.42.893.533q.18.085.293.118a1 1 0 0 0 .101.025 1 1 0 0 0 .1-.025q.114-.034.294-.118c.24-.113.547-.29.893-.533a10.7 10.7 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.8 11.8 0 0 1-2.517 2.453 7 7 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7 7 0 0 1-1.048-.625 11.8 11.8 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 63 63 0 0 1 5.072.56"/>
                        <path d="M9.5 6.5a1.5 1.5 0 0 1-1 1.415l.385 1.99a.5.5 0 0 1-.491.595h-.788a.5.5 0 0 1-.49-.595l.384-1.99a1.5 1.5 0 1 1 2-1.415"/>
                    </svg>
                </button>
                <a href="{{ url "mailmgmt:emails:delete" }}?email={{ urlquery $email.Email }}" class="mailmgmt-action-button mailmgmt-action-delete">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="mailmgmt-action-icon" viewBox="0 0 16 16" data-controller="tooltip" data-tooltip-content-value="{{ T "Delete" }}" data-tooltip-placement-value="bottom">
                        <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"/>
                    </svg>
                </a>
            </div>
        </td>
    </tr>
{{ end }}

<div id="mailmgmt-paginator" class="mailmgmt-list-paginator" hx-swap-oob="true">
    {{ (.Get "view.paginator.object").HTML "page" 5 .Request.URL.Query }}
</div>

{{ end }}