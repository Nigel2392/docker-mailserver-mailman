{{ template "skeleton" . }}

{{ define "title" }}{{ T "Email List" }}{{ end }}

{{ define "css" }}
    <link rel="stylesheet" href="{{ static "mailmgmt/css/mailmgmt.css" }}">
{{ end }}

{{ define "content" }}
    <div class="mailmgmt-object">

        <div class="mailmgmt-header">
            {{ T "Delete E-Mail Data: %s" (.Get "view.object").Email }}
        </div>

        <div class="mailmgmt-content">

        </div>

    </div>
{{ end }}

