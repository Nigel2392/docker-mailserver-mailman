{
"compilerOptions": {
    "noImplicitAny": true,
    "module": "es6",
    "target": "es2017",
    "lib": ["es2017", "dom"],
    "allowJs": true,
    "jsx": "react",
    "jsxFactory": "jsx",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strictNullChecks": false,
    "strictPropertyInitialization": false
  },
  "include": [
    "static_src/**/*.ts",
    "static_src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "vendor"
  ]
}